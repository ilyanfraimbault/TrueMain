FROM node:26-alpine

WORKDIR /workspace/admin

ENV NODE_ENV=development
ENV NITRO_HOST=0.0.0.0
ENV NITRO_PORT=3000

COPY package.json ./
COPY package-lock.json ./
RUN npm ci

COPY . ./

EXPOSE 3000

# Nuxt dev server boots much slower than the production bundle (Vite warm-up,
# first-request compile). Give it a long start_period before failing the
# container so docker compose's `condition: service_healthy` does not time
# out on a cold start.
HEALTHCHECK --interval=10s --timeout=5s --start-period=120s --retries=10 \
    CMD wget --quiet --tries=1 --spider http://localhost:3000/ || exit 1

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
