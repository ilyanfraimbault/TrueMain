POSTGRES_USER=truemain_preprod
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=truemain_preprod
# MongoDB credentials (logs + audit + Riot usage rollups). Keep them
# ALPHANUMERIC — they are embedded in the connection URI.
MONGO_USER=truemain_preprod
MONGO_PASSWORD=REPLACE_ME
# Preprod uses its OWN Riot API key — never the production one. PUUIDs are
# encrypted per API app, so the key and the database form an inseparable pair:
# a fresh key requires a fresh database (and vice versa).
RIOT_API_KEY=RGAPI-REPLACE_ME_PREPROD
OPS_API_KEY=REPLACE_WITH_RANDOM_32+_CHAR_SECRET
PGADMIN_DEFAULT_EMAIL=admin@truemain-preprod.dev
PGADMIN_DEFAULT_PASSWORD=REPLACE_ME
NUXT_API_BASE_URL=http://api:8080

# Admin dashboard (admin/). Preprod is a non-dev environment, so the app
# refuses to boot with the insecure `truemain` defaults: generate real values
# before deploying (e.g. `openssl rand -hex 32` for the session secret, which
# must be >= 32 chars). Placeholders below force an operator to fill them in.
ADMIN_SESSION_PASSWORD=REPLACE_WITH_RANDOM_32+_CHAR_SECRET
ADMIN_USERNAME=REPLACE_WITH_ADMIN_USERNAME
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
