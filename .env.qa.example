POSTGRES_USER=truemain_qa
POSTGRES_PASSWORD=truemain_qa
POSTGRES_DB=truemain_qa
RIOT_API_KEY=RGAPI-REPLACE_ME_QA
PGADMIN_DEFAULT_EMAIL=admin@truemain-qa.dev
PGADMIN_DEFAULT_PASSWORD=admin
NUXT_API_BASE_URL=http://api:8080

# Admin dashboard (admin/). QA is a non-dev environment, so the app refuses to
# boot with the insecure `truemain` defaults: generate real values before
# deploying (e.g. `openssl rand -hex 32` for the session secret, which must be
# >= 32 chars). Placeholders below force an operator to fill them in.
ADMIN_SESSION_PASSWORD=REPLACE_WITH_RANDOM_32+_CHAR_SECRET
ADMIN_USERNAME=REPLACE_WITH_ADMIN_USERNAME
ADMIN_PASSWORD=REPLACE_WITH_STRONG_ADMIN_PASSWORD
