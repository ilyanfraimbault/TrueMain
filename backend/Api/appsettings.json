{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "MongoLogging": {
    "Database": "truemain_logs",
    "LogsCollection": "logs",
    "AuditCollection": "audit_events",
    "Enabled": true,
    "MinimumLevel": "Warning",
    "LogsRetention": "30.00:00:00"
  },
  "Cors": {
    "Origins": []
  },
  "AllowedHosts": "*"
}
