{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    },
    "Mongo": {
      "LogLevel": {
        "Polly": "Error"
      }
    }
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "MongoLogging": {
    "Database": "truemain_logs",
    "LogsCollection": "logs",
    "AuditCollection": "audit_events",
    "Enabled": true,
    "MinimumLevel": "Warning",
    "LogsRetention": "90.00:00:00"
  },
  "Cors": {
    "Origins": []
  },
  "AllowedHosts": "*"
}
