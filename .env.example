POSTGRES_USER=truemain
# Local-dev default only — replace with a strong secret for any shared,
# QA, or production deployment.
POSTGRES_PASSWORD=REPLACE_ME
POSTGRES_DB=truemain
# MongoDB stores diagnostic logs (logs collection, 30-day TTL) and the lossless
# operator-action audit trail (audit_events collection). The compose files build
# MongoLogging__ConnectionString from these credentials, so keep them
# ALPHANUMERIC — reserved URI chars (@ : / ? # %) would break the connection string.
MONGO_USER=truemain
# Local-dev default only — replace with a strong secret for any shared,
# QA, or production deployment.
MONGO_PASSWORD=REPLACE_ME
RIOT_API_KEY=RGAPI-REPLACE_ME
# Required: must be at least 32 characters. Gates the /ops/* endpoints
# behind the X-Ops-Key header. Set per environment and rotate
# independently of the Riot key.
OPS_API_KEY=REPLACE_WITH_RANDOM_32+_CHAR_SECRET
PGADMIN_DEFAULT_EMAIL=admin@truemain.dev
# Local-dev default only — replace with a strong secret for any shared,
# QA, or production deployment.
PGADMIN_DEFAULT_PASSWORD=REPLACE_ME
NUXT_API_BASE_URL=http://api:8080

# --- Admin dashboard (admin/) ---------------------------------------------
# Seals the admin operator session cookie (nuxt-auth-utils reads it as
# NUXT_SESSION_PASSWORD inside the container). Required: must be at least 32
# characters. Generate a fresh random secret per environment.
ADMIN_SESSION_PASSWORD=REPLACE_WITH_RANDOM_32+_CHAR_SECRET
# Single-operator login for the admin dashboard. In qa/prod the dashboard is
# published directly on the host with no TLS, so real credentials are MANDATORY:
# the admin refuses to boot if the username OR password is still `truemain`.
ADMIN_USERNAME=REPLACE_ME
ADMIN_PASSWORD=REPLACE_ME
