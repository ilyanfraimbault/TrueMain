FROM node:24-alpine

WORKDIR /workspace/truemain-web

ENV NODE_ENV=development
ENV NITRO_HOST=0.0.0.0
ENV NITRO_PORT=3000

COPY truemain-web/package.json ./
COPY truemain-web/package-lock.json ./
RUN npm ci

COPY truemain-web/ ./

EXPOSE 3000

CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0", "--port", "3000"]
